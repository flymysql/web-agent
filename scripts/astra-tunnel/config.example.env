# Copy to config.local.env and fill in your SSH login name.
#   copy config.example.env config.local.env
#
# config.local.env is gitignored — do not commit secrets.

ASTRA_SSH_HOST=9.134.186.191
ASTRA_SSH_USER=your_rtx_id
ASTRA_SSH_PORT=36000

# Local port on your PC (curl / web-agent LLM_BASE_URL will use this)
ASTRA_LOCAL_PORT=15722

# Upstream on the 191 machine (astra is HTTP on port 80)
ASTRA_REMOTE_HOST=astra.woa.com
ASTRA_REMOTE_PORT=80
