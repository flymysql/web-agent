{
  "manifest_version": 3,
  "name": "AI Browser Agent",
  "version": "0.1.0",
  "description": "AI-powered browser automation agent with controlled page tools",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "cookies",
    "downloads",
    "webRequest"
  ],
  "host_permissions": [
    "http://localhost:3847/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "AI Browser Agent",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
