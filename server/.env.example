PORT=3847

# ── LLM 配置（OpenAI 兼容端点）─────────────────────────────
# 任何兼容 OpenAI /chat/completions 的服务都可用。
# 优先读取 LLM_*，找不到再回退到 OPENAI_*。
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# ── 常见服务商示例（取消注释并填入 key）──────────────────
# DeepSeek
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
#
# Moonshot (Kimi)
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=moonshot-v1-8k
#
# 阿里通义千问 (DashScope 兼容模式)
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
#
# 本地模型 (Ollama / LM Studio，通常无需 key)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5
# LLM_API_KEY=ollama

# ── 视觉（可选，默认关闭）───────────────────────────────────
# 打开后，每步决策会附带一张当前视口截图给模型（需模型支持多模态/看图）。
# 关闭时行为与纯文本完全一致，不产生额外开销。
# LLM_VISION=1
# 截图精细度：low(默认,省 token/延迟) | high | auto
# LLM_VISION_DETAIL=low

# ── 兼容旧变量（仍可用）────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ── 自定义请求头（JSON）─────────────────────────────────────
# 某些内网/代理端点需要额外请求头，例如 Astra 的 ASTRA_APP_ID。
# LLM_EXTRA_HEADERS={"ASTRA_APP_ID":"your_app_id"}
#
# Astra 内网端点（在 191 等白名单机器上直连）：
# LLM_BASE_URL=http://astra.woa.com/astra-llm/v1
# LLM_API_KEY=ac:xxxxxxxx
# LLM_MODEL=deepseek-v4-pro
# LLM_EXTRA_HEADERS={"ASTRA_APP_ID":"your_app_id"}
#
# Astra 经 SSH 隧道（本机 PC，见 scripts/astra-tunnel/）：
# 1) .\scripts\astra-tunnel\start-tunnel.ps1
# 2) LLM_BASE_URL=http://127.0.0.1:15723/astra-llm/v1  (local-proxy rewrites Host for Node fetch)
#    （其余 LLM_API_KEY / LLM_MODEL / LLM_EXTRA_HEADERS 同上）
